---
---

<section class="min-h-screen bg-[#020617] text-white -mt-5">
    <h1 class="text-3xl font-bold tracking-tight ml-10 mt-10 absolute" id="userName"></h1>
    <p class="mt-2 text-slate-400 ml-10 mt-20 absolute">Generate and manage your secure passwords</p>

    <div class="flex flex-col md:flex-row gap-8 mt-40 absolute w-300 ml-18">
        <div class="flex-1 rounded-2xl border border-slate-800 bg-[#020617]/60 p-6 shadow-[0_0_40px_rgba(0,0,0,0.6)]">
            <div class="flex items-center gap-3 mb-6">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-500/10">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#00b162" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">Generate Password</h2>
                    <p class="text-slate-400 text-sm">Create a strong, secure password</p>
                </div>
            </div>
            <div class="flex justify-center bg-[#0e111a] w-130 ml-2 rounded-xl border-[0.15em] border-[#181e27]">
                <h2 id="passwordGenerated" class="mt-3 mb-3 text-lg text-[#dee5ea]"></h2>
            </div>
            <div class="grid grid-cols-2 gap-4 w-130">
                <div class="flex items-center justify-between bg-[#0e111a] border border-[#1c2330] rounded-xl px-4 py-3">
                    <span class="text-[#cbd5e1] text-sm font-medium">Uppercase (A-Z)</span>
                    <div class="w-12 h-6 flex items-center bg-[#00b162] rounded-full p-1 cursor-pointer">
                    <div class="bg-black w-4 h-4 rounded-full ml-auto"></div>
                    </div>
                </div>
                <div class="flex items-center justify-between bg-[#0e111a] border border-[#1c2330] rounded-xl px-4 py-3">
                    <span class="text-[#cbd5e1] text-sm font-medium">Lowercase (a-z)</span>
                    <div class="w-12 h-6 flex items-center bg-[#00b162] rounded-full p-1 cursor-pointer">
                    <div class="bg-black w-4 h-4 rounded-full ml-auto"></div>
                    </div>
                </div>
                <div class="flex items-center justify-between bg-[#0e111a] border border-[#1c2330] rounded-xl px-4 py-3">
                    <span class="text-[#cbd5e1] text-sm font-medium">Numbers (0-9)</span>
                    <div class="w-12 h-6 flex items-center bg-[#00b162] rounded-full p-1 cursor-pointer">
                    <div class="bg-black w-4 h-4 rounded-full ml-auto"></div>
                    </div>
                </div>
                <div class="flex items-center justify-between bg-[#0e111a] border border-[#1c2330] rounded-xl px-4 py-3">
                    <span class="text-[#cbd5e1] text-sm font-medium">Symbols (!@#)</span>
                    <div class="w-12 h-6 flex items-center bg-[#00b162] rounded-full p-1 cursor-pointer">
                    <div class="bg-black w-4 h-4 rounded-full ml-auto"></div>
                    </div>
                </div>
            </div>
            <div class="ml-8 flex gap-4 flex-wrap">
                <button id="regenerate" class="hover:bg-[#11151c] flex bg-[#151b24] items-center rounded-xl gap-2 w-37 h-10 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 ml-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                    Regenerate
                </button>
                <button id="copy" class="hover:bg-[#11151c] justify-center flex bg-[#151b24] items-center rounded-xl gap-2 w-37 h-10 cursor-pointer">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                    </svg>
                    Copy
                </button>
                <button id='save' class="flex hover:bg-[#008349] items-center bg-[#00ae61] rounded-xl gap-2 w-37 h-10 cursor-pointer text-black">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="ml-9 size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Save
                </button>
            </div>
        </div>
        <div class="flex-1 rounded-2xl border border-slate-800 bg-[#020617]/60 p-6 shadow-[0_0_40px_rgba(0,0,0,0.6)]">
            <div class="flex items-center gap-3 mb-6">
                <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-500/10">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#00b162" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">Saved Passwords</h2>
                    <p class="text-slate-400 text-sm" id="savedTxt"></p>
                </div>
            </div>
        </div>
    </div>

    <script type="module">
        import * as func from  '../../utils/func.js';
        let USERNAME = '';
        let passwordGenerated = ">&[W-H}1Ies|1tTl";
        let SAVED = 0;
        let passwordstxt = 'passwords';
        if (SAVED == 1){
            passwordstxt = 'password';
        }
        const copyBtn = document.getElementById('copy');
        const passwordEl = document.getElementById('passwordGenerated');
        try{
            const pass = func.generatePassword(16, true, true, true, true);
            passwordEl.textContent=pass;
        } catch (err){
            console.log(err);
        }
        document.getElementById('userName').textContent=`Welcome Back, ${USERNAME}`;
        document.getElementById('savedTxt').textContent=`${SAVED} ${passwordstxt} saved`;
        document.getElementById('regenerate').addEventListener("click", ()=>{
            try{
                const pass = func.generatePassword(16, true, true, true, true);
                passwordEl.textContent=pass;
            } catch (err){
                console.log(err.message);
            }
        });
        copyBtn.addEventListener("click", async () => {
            const text = passwordEl.textContent;
            if (!text) return;
            try {
                await navigator.clipboard.writeText(text);
                copyBtn.textContent = "Copied!";
                setTimeout(() => {
                    copyBtn.innerHTML = `
                        <svg class="ml-8" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect width="14" height="14" x="8" y="8" rx="2"/>
                            <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                        </svg>
                        Copy
                    `;
                }, 1500);

            } catch (err) {
                console.log("Error al copiar:", err);
            }
    });
    </script>
</section>