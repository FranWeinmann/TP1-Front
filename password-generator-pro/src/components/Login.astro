---
---

<section class="min-h-screen flex items-center justify-center bg-[#020617] text-white">

  <div class="w-full max-w-md animate-fade">

    <div class="text-center mb-8">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-green-500/10">
        <span class="text-green-400 text-2xl">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </span>
      </div>

      <h1 class="text-3xl font-bold tracking-tight">Welcome back</h1>
      <p class="mt-2 text-slate-400">Sign in to your account to continue</p>
    </div>

    <div class="rounded-2xl border border-slate-800 bg-[#020617]/60 backdrop-blur-xl p-6 shadow-[0_0_40px_rgba(0,0,0,0.6)]">

      <div class="mb-4">
        <label class="block mb-2 text-sm text-slate-400">Email</label>

      <div class="relative">
        <svg 
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="#88909c"
          class="absolute left-3 top-1/2 -translate-y-1/2 size-5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
        <input
          type="email" 
          placeholder="you@example.com"
          class="w-full rounded-lg border border-slate-800 bg-[#020617] pl-10 pr-4 py-3 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500"
        />

      </div>

      <div class="mb-5">
        <label class="block mb-2 text-sm text-slate-400">Password</label>

        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#88909c" class="size-5 absolute left-3 top-1/2 -translate-y-1/2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
          <input 
            id="password"
            type="password"
            placeholder="Enter your password"
            class="w-full rounded-lg border border-slate-800 bg-[#020617] pl-10 pr-4 py-3 text-sm text-white placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-green-500"
          />

          <button 
            id="togglePass"
            type="button"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-white transition"
          >
            <svg id="eye" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" cursor="pointer">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
            <svg id='blocked' xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6 hidden" cursor="pointer">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
            </svg>
          </button>
        </div>
      </div>

      <button onclick="window.location.href='home'" class="w-full bg-green-500 hover:bg-green-600 transition-all duration-300 py-3 rounded-lg font-semibold flex items-center justify-center gap-2 hover:scale-[1.02]">
        Sign in →
      </button>

      <p class="text-center text-sm text-slate-500 mt-4">
        Don't have an account?
        <span class="text-green-400 hover:underline cursor-pointer">Sign up</span>
      </p>

    </div>

  </div>

  <script>
    const btn = document.getElementById("togglePass");
    const input = document.getElementById("password");
    const eye = document.getElementById("eye");
    const blocked = document.getElementById("blocked");

    btn?.addEventListener("click", () => {
      input.type = input.type === "password" ? "text" : "password";
      eye.classList.toggle("hidden");
      blocked.classList.toggle("hidden");
    });
  </script>

</section>