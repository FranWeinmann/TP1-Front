---
---

<header class="sticky top-0 z-50 w-full border-b border-white/10 bg-[#020617] backdrop-blur-xl">

  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">

    <div class="flex items-center gap-3">
      <div id="firstDiv" class="flex h-10 w-10 items-center justify-center rounded-xl bg-[#031715]">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#009152" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
      </div>

      <span id="title" class="text-white font-semibold text-lg tracking-tight">
        Password Generator Pro
      </span>
    </div>

    <button 
      id="themeToggle"
      class="relative w-14 h-8 flex items-center rounded-full bg-[#151b24] p-1 transition"
    >
      <span 
        id="circle"
        class="absolute right-1 flex h-6 w-6 items-center justify-center rounded-full bg-[#00b162] transition-all duration-300"
      >
        <svg id="moon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#014d2e" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
        <svg id="sun" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#ffffff" class="size-5 hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
      </span>
    </button>

  </div>

  <script>
    const btn = document.getElementById("themeToggle");
    const circle = document.getElementById("circle");
    const sun = document.getElementById("sun");
    const moon = document.getElementById("moon");

    btn?.addEventListener("click", () => {
      sun.classList.toggle("hidden");
      moon.classList.toggle("hidden");
      circle.classList.toggle("-translate-x-6");
      document.documentElement.classList.toggle("light");
    });
  </script>

</header>